# =============================================
# NexusIQ — Environment Variables
# Copy this file to .env and fill in your keys
# =============================================

# --- Gemini API (Required for AI features) ---
# Get your key at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# --- Database (Optional — defaults to SQLite) ---
# For production, use a PostgreSQL URL:
# DATABASE_URL=postgresql://user:password@host:5432/nexusiq
DATABASE_URL=sqlite:///./nexusiq.db

# --- Neo4j Knowledge Graph (Optional) ---
# Leave blank to run without graph sync
NEO4J_URI=
NEO4J_USER=
NEO4J_PASSWORD=

# --- Frontend (Next.js) ---
# Point this at your running backend
NEXT_PUBLIC_API_URL=http://localhost:8000
